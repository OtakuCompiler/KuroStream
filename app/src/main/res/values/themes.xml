<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">KuroStream</string>
    <string name="browse_title">KuroStream</string>

    <style name="Theme.AnimeStreamTV" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/tv_background</item>
        <item name="android:colorPrimary">@color/tv_primary</item>
        <item name="android:colorAccent">@color/tv_secondary</item>
    </style>

    <style name="Theme.AnimeStreamTV.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.AnimeStreamTV.Fullscreen" parent="Theme.AnimeStreamTV.NoActionBar">
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <color name="tv_background">#FF0A0A0F</color>
    <color name="tv_primary">#FF7C4DFF</color>
    <color name="tv_secondary">#FF00E5FF</color>
    <color name="tv_surface">#FF14141F</color>
    <color name="tv_error">#FFCF6679</color>
</resources>
